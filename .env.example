# ============================================================
# NidoApp — Variables de entorno
# Copiá este archivo como .env.local y completá los valores
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# URL pública de tu proyecto Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anon/pública de Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave service_role (secreta, solo servidor) — Settings > API
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── WhatsApp (Meta Cloud API) ──────────────────────────────
# Token de acceso permanente de tu app de Meta (System User token)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID del número de teléfono de WhatsApp Business (Meta > WhatsApp > API Setup)
WHATSAPP_PHONE_NUMBER_ID=1234567890123456

# App Secret de tu aplicación Meta (Meta > App Dashboard > Settings > Basic)
WHATSAPP_APP_SECRET=abcdef1234567890abcdef1234567890

# Token de verificación del webhook (lo elegís vos, debe coincidir con el configurado en Meta)
WHATSAPP_VERIFY_TOKEN=mi_token_secreto_de_verificacion

# ── Groq (IA para parseo de mensajes) ─────────────────────
# API Key de Groq (console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Lemon Squeezy (billing) ───────────────────────────────
# API Key de Lemon Squeezy (app.lemonsqueezy.com > Settings > API)
LEMONSQUEEZY_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9...

# Secreto para verificar webhooks de Lemon Squeezy (Settings > Webhooks)
LEMONSQUEEZY_WEBHOOK_SECRET=mi_webhook_secret

# ID de tu tienda en Lemon Squeezy (aparece en la URL del dashboard)
LEMONSQUEEZY_STORE_ID=12345

# ID de variante del plan "Nido" en Lemon Squeezy
LEMONSQUEEZY_VARIANT_NIDO=111111

# ID de variante del plan "Casa" en Lemon Squeezy
LEMONSQUEEZY_VARIANT_CASA=222222

# ── Push Notifications (Web Push / VAPID) ─────────────────
# Clave pública VAPID (generada con: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clave privada VAPID (secreta, solo servidor)
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email de contacto para VAPID (requerido por el protocolo)
VAPID_EMAIL=mailto:tu@email.com

# Secreto para proteger el endpoint interno de notificaciones push
PUSH_NOTIFY_SECRET=mi_secreto_para_push_notify

# ── App ───────────────────────────────────────────────────
# URL pública de la aplicación (sin barra final)
NEXT_PUBLIC_APP_URL=https://tu-dominio.com
